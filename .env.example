# Application
APP_NAME=CatDetect
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./catdetect.db

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML
YOLO_MODEL=yolov8s.pt
DETECTION_CONFIDENCE=0.5
IDENTIFICATION_THRESHOLD=0.6
DETECTION_FPS=5

# Cameras
MAX_CAMERAS=3

# Recording
RECORDING_PRE_ROLL_SECONDS=5
RECORDING_POST_ROLL_SECONDS=10
RECORDING_MAX_DURATION=120
RECORDING_MAX_CONCURRENT=2
RECORDING_CRF=23
RECORDING_RESOLUTION=1280x720
RECORDING_FPS=30

# Paths
MODELS_DIR=./models
RECORDINGS_DIR=./recordings
THUMBNAILS_DIR=./thumbnails
DATA_DIR=./data

# Admin (used by create_admin.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@localhost
