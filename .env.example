# Application
APP_NAME=CatDetect
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./catdetect.db

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML
YOLO_MODEL=yolov8s.pt
DETECTION_CONFIDENCE=0.5
IDENTIFICATION_THRESHOLD=0.6
DETECTION_FPS=5

# Cameras
MAX_CAMERAS=3

# Recording
RECORDING_PRE_ROLL_SECONDS=5
RECORDING_POST_ROLL_SECONDS=10
RECORDING_MAX_DURATION=120
RECORDING_MAX_CONCURRENT=2
RECORDING_CRF=23
RECORDING_RESOLUTION=1280x720
RECORDING_FPS=30

# Paths
MODELS_DIR=./models
RECORDINGS_DIR=./recordings
THUMBNAILS_DIR=./thumbnails
DATA_DIR=./data

# Admin (used by create_admin.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@localhost

# Remote Training (client-server architecture)
# Server-side: set TRAINING_API_KEY and run `python scripts/training_server.py`
TRAINING_API_KEY=change-me-to-a-random-key
TRAINING_PORT=8001
TRAINING_HOST=0.0.0.0
# Jetson-side: set these and run `./scripts/training_client.sh`
TRAINING_SERVER_HOST=192.168.1.200
TRAINING_SERVER_PORT=8001
TRAINING_SERVER_SSH=user@192.168.1.200
TRAINING_SERVER_DIR=~/cat-detection-project
CATDETECT_TOKEN=your-jwt-token
CATDETECT_URL=http://localhost:8000
